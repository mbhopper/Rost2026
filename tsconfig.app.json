{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "react-router-dom": ["vendor/react-router-dom/index.d.ts"],
      "zustand": ["vendor/zustand/index.d.ts"],
      "clsx": ["vendor/clsx/index.d.ts"],
      "class-variance-authority": ["vendor/class-variance-authority/index.d.ts"],
      "qrcode.react": ["vendor/qrcode.react/index.d.ts"],
      "date-fns": ["vendor/date-fns/index.d.ts"],
      "lucide-react": ["vendor/lucide-react/index.d.ts"]
    }
  },
  "include": ["src"]
}
